---
const cards = [
  {
    title: 'La publicité vous épuise',
    body: "Vous payez pour chaque clic. Dès que le budget s'arrête, la visibilité disparaît. Aucun actif durable ne se construit.",
    path: 'M12 2v4M12 18v4M2 12h4M18 12h4M5 5l2.5 2.5M16.5 16.5 19 19M19 5l-2.5 2.5M7.5 16.5 5 19',
    circle: { cx: 12, cy: 12, r: 3.2 },
  },
  {
    title: 'Vos clients ne vous trouvent pas',
    body: 'Quand on cherche vos produits ou services sur Google, ce sont vos concurrents qui apparaissent. Vous restez en bas de page.',
    path: 'm21 21-4.3-4.3',
    circle: { cx: 11, cy: 11, r: 7 },
  },
  {
    title: "Votre culture n'est pas valorisée",
    body: 'Votre ancrage local et votre identité sont vos plus grandes forces — mais ils sont absents de votre référencement.',
    path: 'M12 21s-7-4.5-7-10a7 7 0 0 1 14 0c0 5.5-7 10-7 10Z',
    circle: { cx: 12, cy: 11, r: 2.4 },
  },
];
---

<section class="sec problem">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker">Le constat</span>
      <h2 class="sec-title">Un fort potentiel,<br />mais invisible sur Google.</h2>
      <p>
        Trop souvent, les marques afro-caribéennes ont tout pour réussir — un produit, une communauté, une histoire —
        mais restent invisibles face à des acteurs plus installés ou mieux financés.
      </p>
    </div>
    <div class="prob-grid">
      {
        cards.map((c) => (
          <div class="prob-card reveal">
            <div class="prob-ic">
              <svg viewBox="0 0 24 24">
                <path d={c.path} />
                <circle cx={c.circle.cx} cy={c.circle.cy} r={c.circle.r} />
              </svg>
            </div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

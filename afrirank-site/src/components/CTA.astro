---
const calendly = 'https://calendly.com/contact-advised-seo/30min?back=1';
---

<section class="sec" id="contact">
  <div class="wrap">
    <div class="cta-band reveal">
      <img src="/images/icon-cream.png" class="icon-watermark" alt="" />
      <h2>Prêt à devenir visible sur Google ?</h2>
      <p>
        Réservez un appel découverte gratuit. On analyse votre situation et on voit comment AfriRank peut faire grandir
        votre marque.
      </p>
      <div class="cta-actions">
        <a href={calendly} target="_blank" rel="noopener" class="btn btn--orange">
          Réserver un appel gratuit
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
        </a>
        <a href="mailto:contact@afrirank.com" class="btn btn--cream">contact@afrirank.com</a>
      </div>
    </div>
  </div>
</section>

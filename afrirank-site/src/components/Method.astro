---
const steps = [
  { num: '01', title: 'Audit SEO', body: 'On analyse votre site, vos mots-clés et votre marché local pour repérer chaque opportunité de visibilité.' },
  { num: '02', title: 'Stratégie locale & culturelle', body: 'On construit une feuille de route ancrée dans votre territoire, votre communauté et votre identité de marque.' },
  { num: '03', title: 'Optimisation', body: 'On optimise votre site, vos fiches Google et vos contenus pour grimper sur les bons mots-clés.' },
  { num: '04', title: 'Suivi & croissance', body: 'On mesure, on ajuste et on fait grandir votre visibilité de façon durable et authentique.' },
];
---

<section class="sec" id="methode">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="kicker">La méthode</span>
      <h2 class="sec-title">Une approche claire, en 4 étapes.</h2>
      <p>
        Pas de jargon, pas de promesses exagérées. Une démarche stratégique, locale et culturelle, pensée pour votre
        marque et votre communauté.
      </p>
    </div>
    <div class="method-grid">
      {
        steps.map((s) => (
          <div class="step reveal">
            <div class="step-num">
              {s.num}
              <span class="step-dot" />
            </div>
            <h3 set:html={s.title} />
            <p>{s.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

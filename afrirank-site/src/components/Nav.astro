---
const { active = '' } = Astro.props;
const links = [
  { href: '/', label: 'Accueil', key: 'accueil' },
  { href: '/diagnostic-seo/', label: 'Diagnostic', key: 'diagnostic' },
  { href: '/accompagnement/', label: 'Accompagnement', key: 'accompagnement' },
  { href: '/seo-culturel/', label: 'SEO culturel', key: 'seo-culturel' },
  { href: '/seo-marques-afro-caribeennes/', label: 'Guides', key: 'guides' },
  { href: '/a-propos/', label: 'À propos', key: 'a-propos' },
  { href: '/contact/', label: 'Contact', key: 'contact' },
];
const calendly = 'https://calendly.com/contact-advised-seo/30min?back=1';
---
<header class="nav" id="nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand" aria-label="AfriRank — accueil"><img src="/images/logo-dark.png" alt="AfriRank" /></a>
    <nav class="nav-links">
      {links.map((l) => <a href={l.href} class={active === l.key ? 'active' : undefined}>{l.label}</a>)}
    </nav>
    <a href={calendly} target="_blank" rel="noopener" class="btn btn--blue nav-cta">Réserver mon Diagnostic
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"></path></svg>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Menu"><span></span></button>
  </div>
</header>

<div class="mobile-menu" id="mobileMenu">
  {links.map((l) => <a href={l.href}>{l.label}</a>)}
  <a href={calendly} target="_blank" rel="noopener" class="btn btn--orange">Réserver mon Diagnostic
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"></path></svg>
  </a>
</div>

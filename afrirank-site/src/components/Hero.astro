---
const calendly = 'https://calendly.com/contact-advised-seo/30min?back=1';
---

<section class="hero wrap" id="accueil">
  <div class="hero-top">
    <span class="hero-eyebrow reveal">
      <img src="/images/icon-orange.png" alt="" /> SEO local &amp; culturel · Diaspora afro-caribéenne
    </span>
    <h1 class="reveal">Soyez visible sur Google, <em>sans publicité</em></h1>
    <p class="hero-sub reveal">
      AfriRank aide les marques afro-caribéennes à devenir visibles sur Google grâce au SEO local et culturel.
    </p>
    <div class="hero-actions reveal">
      <a href={calendly} target="_blank" rel="noopener" class="btn btn--orange">
        Réserver mon audit SEO
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
      </a>
      <a href="#methode" class="btn btn--ghost">Découvrir la méthode</a>
    </div>
    <span class="hero-note reveal"><b>Sans engagement</b> · Premier audit offert · Réponse sous 48h</span>
  </div>

  <div class="gallery reveal">
    <img class="gimg g-tall" src="/images/HERO.png" alt="AfriRank — visibilité pour la diaspora afro-caribéenne" />
    <div class="img-slot g-mid">Entrepreneure / artisane</div>
    <div class="img-slot g-tall">Portrait cliente</div>
    <div class="img-slot g-low">Bureau / lifestyle</div>
    <div class="img-slot g-mid">Commerce local</div>
  </div>
</section>

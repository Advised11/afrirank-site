---
const calendly = 'https://calendly.com/contact-advised-seo/30min?back=1';
const items = [
  'Analyse technique & mots-clés',
  'Étude de votre marché local',
  'Analyse de la concurrence',
  "Plan d'action priorisé",
  'Restitution en visio (45 min)',
  'Recommandations culturelles',
];
const check = 'M20 6 9 17l-5-5';
---

<section class="sec" id="offre">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="kicker">Par où commencer</span>
      <h2 class="sec-title">Avant tout : l'audit SEO.</h2>
      <p>Une séance unique, sans engagement, pour savoir exactement où vous en êtes et par où commencer.</p>
    </div>
    <div class="audit-card reveal">
      <div class="audit-left">
        <span class="offer-tag">Audit SEO · One-shot</span>
        <h2>Le diagnostic complet de votre visibilité.</h2>
        <p>
          On analyse votre site, votre marché et vos concurrents, puis on vous remet un plan d'action clair et priorisé.
          Le point de départ idéal, même si vous ne continuez pas avec AfriRank.
        </p>
        <ul class="audit-list">
          {
            items.map((i) => (
              <li>
                <svg viewBox="0 0 24 24" fill="none"><path d={check} /></svg>
                {i}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="audit-right">
        <div class="audit-price">290€<span>séance one-shot</span></div>
        <a href={calendly} target="_blank" rel="noopener" class="btn btn--orange">
          Réserver mon audit
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
        </a>
        <span class="audit-note">Sans engagement · Déductible si vous poursuivez avec un accompagnement</span>
      </div>
    </div>
  </div>
</section>

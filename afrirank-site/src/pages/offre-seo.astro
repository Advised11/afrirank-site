---
import Base from '../layouts/Base.astro';
const calendly = 'https://calendly.com/contact-advised-seo/30min?back=1';
---
<Base
  title="SEO & GEO pour marques afro-caribéennes — AfriRank"
  description="Rendez votre marque afro-caribéenne visible sur Google et dans les réponses IA — durablement, sans dépendre de la pub. Réservez un appel de 30 min, sans engagement."
  noindex={true}
  bare={true}>

<!-- En-tête minimal (pas de menu : page dédiée aux campagnes) -->
<header class="lp-head">
  <div class="wrap lp-head-inner">
    <img src="/images/logo-dark.png" alt="AfriRank" class="lp-logo" />
    <a href={calendly} class="btn btn--blue lp-head-cta">Réserver mon appel
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </div>
</header>

<!-- HERO -->
<section class="hero hero--page wrap lp-hero">
  <div class="hero-top">
    <span class="hero-eyebrow reveal"><img src="/images/icon-orange.png" alt="" /> SEO &amp; GEO · marques afro-caribéennes</span>
    <h1 class="reveal">Votre marque mérite d'être <em>trouvée</em> — sur Google et dans les IA.</h1>
    <p class="hero-sub reveal">La pub, c'est un loyer : vous payez, vous êtes visible ; vous arrêtez, vous disparaissez. AfriRank construit une visibilité organique <strong>que vous possédez</strong>, ancrée dans votre marché et votre culture.</p>
    <div class="lp-cta reveal">
      <a href={calendly} class="btn btn--orange">Réserver mon appel de 30 min
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <span class="lp-cta-note">Sans engagement · réponse sous 48 h</span>
    </div>
    <p class="lp-trust reveal">11 ans d'expertise SEO · Groupe SEB · LumApps · Rubix · Bonduelle · BPIFrance</p>
  </div>
</section>

<!-- CE QUE VOUS OBTENEZ -->
<section class="sec lp-sec">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="kicker">Ce que vous obtenez</span>
      <h2 class="sec-title">Une visibilité durable, pas un budget pub sans fin.</h2>
    </div>
    <div class="lp-benefits">
      <div class="lp-benefit reveal">
        <span class="v-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3v18h18M7 14l4-4 3 3 5-6"/></svg></span>
        <h3>Du trafic que vous possédez</h3>
        <p>Un canal organique qui continue de travailler quand vous coupez la pub.</p>
      </div>
      <div class="lp-benefit reveal">
        <span class="v-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3 4 7v5c0 4.5 3.4 7.5 8 9 4.6-1.5 8-4.5 8-9V7Z"/></svg></span>
        <h3>SEO culturel</h3>
        <p>Le vocabulaire, les intentions et les codes de votre communauté — qu'une agence généraliste ignore.</p>
      </div>
      <div class="lp-benefit reveal">
        <span class="v-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M8 12h8M12 8v8"/></svg></span>
        <h3>Visibilité dans les IA (GEO)</h3>
        <p>Être cité par ChatGPT, Perplexity et Google AI, là où se prennent désormais les décisions.</p>
      </div>
      <div class="lp-benefit reveal">
        <span class="v-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3 4 7v5c0 4.5 3.4 7.5 8 9 4.6-1.5 8-4.5 8-9V7Z"/><path d="m9 12 2 2 4-4"/></svg></span>
        <h3>Un expert senior, un seul interlocuteur</h3>
        <p>L'expertise des grands comptes, accountable de bout en bout — et qui vous rend les clés.</p>
      </div>
    </div>
  </div>
</section>

<!-- PREUVE -->
<section class="sec lp-sec lp-proof">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="kicker">La preuve</span>
      <h2 class="sec-title">Une expertise senior, mesurable.</h2>
    </div>
    <div class="stats">
      <div class="stat reveal"><div class="num">11 ans</div><div class="lbl">d'expérience SEO, en agence puis chez l'annonceur</div></div>
      <div class="stat reveal"><div class="num">23 sites</div><div class="lbl">migrés en 2 ans pour le Groupe SEB (lead SEO technique)</div></div>
      <div class="stat reveal"><div class="num">+59 %</div><div class="lbl">de MQL générés chez LumApps (SaaS B2B)</div></div>
      <div class="stat reveal"><div class="num">300+</div><div class="lbl">contenus IA-driven produits en 2 ans</div></div>
    </div>
  </div>
</section>

<!-- OFFRE / RÉASSURANCE + CTA FINAL -->
<section class="sec lp-sec">
  <div class="wrap">
    <div class="cta-band reveal">
      <img src="/images/icon-cream.png" class="icon-watermark" alt="" />
      <span class="kicker" style="color:var(--orange);justify-content:center">Par où commencer</span>
      <h2>Le Diagnostic AfriRank.</h2>
      <p>30 minutes pour voir si votre marché justifie une stratégie organique — et chiffrer le chiffre d'affaires que vous laissez aujourd'hui à vos concurrents. Sans engagement.</p>
      <div class="cta-actions">
        <a href={calendly} class="btn btn--orange">Réserver mon appel de 30 min
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="mailto:contact@advised-seo.fr" class="btn btn--cream">contact@advised-seo.fr</a>
      </div>
    </div>
  </div>
</section>

<!-- Pied minimal (conformité Ads : marque + mentions légales) -->
<footer class="lp-foot">
  <div class="wrap lp-foot-inner">
    <img src="/images/logo-dark.png" alt="AfriRank" class="lp-foot-logo" />
    <span>© 2026 AfriRank — Francis Ndimba</span>
    <a href="/mentions-legales/">Mentions légales</a>
    <a href="mailto:contact@advised-seo.fr">contact@advised-seo.fr</a>
  </div>
</footer>

<!-- Vue de la landing payante (utile pour audiences / remarketing dans GTM) -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ event: 'lp_view', lp: 'offre-seo', page_path: location.pathname });
</script>

<style>
  .lp-head {
    position: sticky; top: 0; z-index: 50;
    background: rgba(249, 246, 239, .9); backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .lp-head-inner { display: flex; align-items: center; justify-content: space-between; padding-top: 14px; padding-bottom: 14px; }
  .lp-logo { height: 30px; width: auto; }
  .lp-hero .hero-top { text-align: center; max-width: 820px; margin: 0 auto; }
  .lp-hero .hero-sub { margin-left: auto; margin-right: auto; }
  .lp-cta { display: flex; flex-direction: column; align-items: center; gap: 10px; margin-top: 30px; }
  .lp-cta-note { font-size: 13.5px; color: var(--ink-45); }
  .lp-trust { margin-top: 30px; font-size: 13px; letter-spacing: .02em; color: var(--ink-45); text-transform: uppercase; }
  .lp-sec { padding: clamp(56px, 7vw, 96px) 0; }
  .lp-benefits { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(16px, 2vw, 24px); }
  .lp-benefit { background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: clamp(22px, 2.4vw, 30px); }
  .lp-benefit .v-ic { display: inline-flex; width: 44px; height: 44px; align-items: center; justify-content: center; border-radius: 12px; background: var(--beige); color: var(--orange); margin-bottom: 16px; }
  .lp-benefit .v-ic svg { width: 22px; height: 22px; }
  .lp-benefit h3 { font-size: 18px; margin-bottom: 8px; }
  .lp-benefit p { color: var(--ink-60); font-size: 15px; line-height: 1.6; }
  .lp-proof { background: var(--beige); }
  .lp-foot { border-top: 1px solid var(--line); padding: 28px 0; }
  .lp-foot-inner { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 10px 22px; font-size: 13.5px; color: var(--ink-60); }
  .lp-foot-logo { height: 22px; width: auto; opacity: .9; }
  .lp-foot a { color: var(--ink-60); text-decoration: underline; text-underline-offset: 2px; }
  .lp-foot a:hover { color: var(--orange); }
  @media (max-width: 900px) { .lp-benefits { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) {
    .lp-benefits { grid-template-columns: 1fr; }
    .lp-head-cta { display: none; }
  }
</style>
</Base>

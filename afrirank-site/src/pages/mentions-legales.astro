<style>
  .legal { max-width: 780px; }
  .legal .updated { font-size: 14px; color: var(--ink-45); margin: 0 0 36px; }
  .legal h2 { font-size: clamp(22px, 2.6vw, 30px); margin: 48px 0 14px; }
  .legal p { color: var(--ink-60); font-size: 16.5px; line-height: 1.75; margin: 0 0 14px; text-wrap: pretty; }
  .legal ul { color: var(--ink-60); font-size: 16.5px; line-height: 1.7; margin: 0 0 18px; padding-left: 1.15em; }
  .legal li { margin-bottom: 7px; }
  .legal strong { color: var(--blue); font-weight: 600; }
  .legal a { color: var(--orange); text-decoration: underline; text-underline-offset: 2px; }
  .legal a:hover { color: var(--orange-deep); }
</style>
</Base>

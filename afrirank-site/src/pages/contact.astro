---
import Base from '../layouts/Base.astro';
const jsonLd = "";
---
<Base title="Contact — AfriRank | Réserver votre Diagnostic SEO" description="Échangeons 30 minutes sur votre marque et votre potentiel organique. Réservez un appel ou écrivez à AfriRank." active="contact" jsonLd={jsonLd}>
<section class="hero hero--page wrap" style="padding-bottom:0">
  <div class="hero-top">
    <span class="hero-eyebrow reveal"><img src="/images/icon-orange.png" alt="" /> Contact</span>
    <h1 class="reveal">Parlons de <em>votre visibilité</em>.</h1>
    <p class="hero-sub reveal">30 minutes pour voir si votre marché justifie une stratégie organique — et ce qu'elle peut rapporter. Sans engagement.</p>
  </div>
</section>

<!-- CONTACT GRID -->
<section class="sec">
  <div class="wrap contact-grid">
    <div class="contact-aside reveal">
      <a href="https://calendly.com/contact-advised-seo/30min?back=1" target="_blank" rel="noopener" class="contact-line" style="text-decoration:none">
        <span class="cl-ic"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M9 16l2 2 4-4"/></svg></span>
        <span><b>Réserver un appel</b><span>Créneau de 30 min via Calendly →</span></span>
      </a>
      <a href="mailto:contact@advised-seo.fr" class="contact-line">
        <span class="cl-ic"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></span>
        <span><b>Email</b><span>contact@advised-seo.fr</span></span>
      </a>
      <a href="https://www.linkedin.com/in/francisndimba" target="_blank" rel="noopener" class="contact-line">
        <span class="cl-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M16 8a6 6 0 0 1 6 6v6h-4v-6a2 2 0 0 0-4 0v6h-4v-6a6 6 0 0 1 6-6Z"/><rect x="2" y="9" width="4" height="11"/><circle cx="4" cy="4" r="2"/></svg></span>
        <span><b>LinkedIn</b><span>Francis Ndimba →</span></span>
      </a>
      <div class="note-card dark" style="margin-top:4px">
        <span class="kicker">Le bon réflexe</span>
        <h3 style="font-size:21px">Commencez par le Diagnostic</h3>
        <p>Le point de départ idéal : on chiffre l'opportunité avant toute décision d'accompagnement.</p>
      </div>
    </div>

    <form class="form reveal" onsubmit="return false">
      <div class="field">
        <label for="f-nom">Nom</label>
        <input id="f-nom" type="text" name="nom" placeholder="Votre nom" autocomplete="name" />
      </div>
      <div class="field">
        <label for="f-marque">Marque</label>
        <input id="f-marque" type="text" name="marque" placeholder="Le nom de votre marque" />
      </div>
      <div class="field">
        <label for="f-site">Site web</label>
        <input id="f-site" type="url" name="site" placeholder="https://" autocomplete="url" />
      </div>
      <div class="field">
        <label for="f-message">Message</label>
        <textarea id="f-message" name="message" placeholder="Parlez-moi de votre marque et de votre objectif…"></textarea>
      </div>
      <a href="mailto:contact@advised-seo.fr" class="btn btn--orange" id="sendBtn">Envoyer
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <p style="font-size:12.5px;color:var(--ink-45);margin-top:14px;text-align:center">Ou écrivez directement à contact@advised-seo.fr — réponse sous 48h.</p>
    </form>
  </div>
</section>

<script is:inline>
  // Prefill mailto from the form so "Envoyer" carries the message
  var sendBtn = document.getElementById('sendBtn');
  if (sendBtn) {
    sendBtn.addEventListener('click', function () {
      var nom = (document.getElementById('f-nom').value || '').trim();
      var marque = (document.getElementById('f-marque').value || '').trim();
      var site = (document.getElementById('f-site').value || '').trim();
      var msg = (document.getElementById('f-message').value || '').trim();
      var subject = 'Contact AfriRank' + (marque ? ' — ' + marque : '');
      var body = 'Nom : ' + nom + '\nMarque : ' + marque + '\nSite : ' + site + '\n\n' + msg;
      sendBtn.setAttribute('href', 'mailto:contact@advised-seo.fr?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body));
    });
  }
</script>
</Base>
